{
  "name": "@no-wms/supabase",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./types": "./src/database.types.ts"
  },
  "scripts": {
    "generate-types": "supabase gen types typescript --local > src/database.types.ts",
    "db:reset": "supabase db reset && tsx scripts/seed-auth.ts",
    "db:migrate": "supabase migration up",
    "db:push:staging": "supabase db push --linked --db-url $STAGING_DB_URL",
    "typecheck": "tsc --noEmit",
    "seed:auth": "tsx scripts/seed-auth.ts",
    "test": "echo 'No tests yet'"
  },
  "devDependencies": {
    "@no-wms/tsconfig": "workspace:*",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
